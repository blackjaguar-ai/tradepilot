# ─────────────────────────────────────────────────────────────
# TradePilot — variables de entorno
# Copia este archivo a .env y rellena con tus credenciales REALES.
# .env está en .gitignore: nunca se sube al repo.
# ─────────────────────────────────────────────────────────────

# --- Qwen (API OpenAI-compatible vía Model Studio) ---
# Crea la key en Model Studio -> ícono de llave / avatar -> API Keys -> Create API Key.
# IMPORTANTE: el base_url depende de tu Workspace ID y región (lo ves en
# Model Studio -> selector "Default Workspace" -> Workspace ID).
#   Singapore:       https://{WorkspaceId}.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
#   Japan (Tokyo):    https://{WorkspaceId}.ap-northeast-1.maas.aliyuncs.com/compatible-mode/v1
#   US (Virginia):    https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   China (Beijing):  https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
# Las API keys NO son intercambiables entre regiones: usa la key creada en la
# MISMA región/workspace que este base_url.
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_BASE_URL=https://ws-fxkh5ae28kyy8a02.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1

# Modelos: barato para clasificar, caro solo para el output final.
# IMPORTANTE: el free quota (1M tokens, 90 días) es POR MODELO, no compartido.
# qwen-turbo ya no se actualiza (Alibaba recomienda qwen-flash en su lugar).
QWEN_MODEL_FAST=qwen-flash
QWEN_MODEL_SMART=qwen-plus
# Opcional para la demo grabada del hero flow (usa su propio pool de 1M tokens):
# QWEN_MODEL_SMART=qwen3.7-max

# --- Alibaba Cloud Tablestore (OTS) ---
# Endpoint: lo ves en la consola de Tablestore, en la instancia que crees.
# Formato: https://<instancia>.<region>.ots.aliyuncs.com
TABLESTORE_ENDPOINT=https://tradepilot.ap-southeast-1.ots.aliyuncs.com
TABLESTORE_INSTANCE=tradepilot
TABLESTORE_ACCESS_KEY_ID=LTAI5xxxxxxxxxxxxxxxxxxx
TABLESTORE_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Región de despliegue (Function Compute) ---
ALIYUN_REGION=ap-southeast-1
